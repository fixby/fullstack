#!/usr/bin/env bash
# openclaw-review-read — 读取审查日志和配置用于仪表盘
# 用法: openclaw-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/openclaw-slug" 2>/dev/null)"
OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
cat "$OPENCLAW_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/openclaw-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
