#!/usr/bin/env bash
# openclaw-review-log — 原子化记录审查结果
# 用法: openclaw-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/openclaw-slug" 2>/dev/null)"
OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
mkdir -p "$OPENCLAW_HOME/projects/$SLUG"
echo "$1" >> "$OPENCLAW_HOME/projects/$SLUG/$BRANCH-reviews.jsonl"
