#!/usr/bin/env bash
# fullstack-config — 读写 ~/.fullstack/config.yaml 配置文件
#
# 用法:
#   fullstack-config get <key>          — 读取配置值
#   fullstack-config set <key> <value>  — 写入配置值
#   fullstack-config list               — 显示所有配置
#
# 环境变量覆盖 (用于测试):
#   FULLSTACK_STATE_DIR  — 覆盖 ~/.fullstack 状态目录
set -euo pipefail

STATE_DIR="${FULLSTACK_STATE_DIR:-$HOME/.fullstack}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?用法: openclaw-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?用法: openclaw-config set <key> <value>}"
    VALUE="${3:?用法: openclaw-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      sed -i '' "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "用法: openclaw-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
