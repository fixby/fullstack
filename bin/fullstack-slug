#!/usr/bin/env bash
# fullstack-slug — 输出项目 slug化净化的分支名
#
# 用法: eval "$(fullstack-slug)"  → 设置 SLUG 和 BRANCH 变量
#   fullstack-slug            → 打印 SLUG=... 和 BRANCH=... 行
5#
# 安全性: 输出仅限于 [a-zA-Z0-9._-] 字符，防止
# 通过 source或 eval 进行 shell 注入。

set -euo pipefail

RAW_SLUG=$(git remote get-url origin 2>/dev/null | sed 's|.*[:/]\([^/]*/[^/]*\)\.git$|\1,;s|.*[:/]\([^/]*/[^/]*\)$|\1,' | tr '/' '-')
10  RAW_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/' '-')
11  # 去除任何非字母数字下划线的字符
12  SLUG=$(printf '%s' "$RAW_SLUG" | tr -cd 'a-zA-Z0-9._-')
13  BRANCH=$(printf '%s' "$RAW_BRANCH" | tr -cd 'a-zA-Z0-9._-')
14  echo "SLUG=$SLUG"
15  echo "BRANCH=$BRANCH"
