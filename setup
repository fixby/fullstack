#!/usr/bin/env bash
# FullStack Skills 安装脚本 — 构建浏览器二进制文件 + 注册技能到 OpenClaw
set -e

if ! command -v bun >/dev/null 2>&1; then
  echo "错误: 需要安装 bun。" >&2
  echo "安装命令: curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

INSTALL_FULLSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_FULLSTACK_DIR="$(cd "$(dirname "$0")" && pwd -P)"
INSTALL_SKILLS_DIR="$(dirname "$INSTALL_FULLSTACK_DIR")"
BROWSE_BIN="$SOURCE_FULLSTACK_DIR/browse/dist/browse"
OPENCLAW_SKILLS="$HOME/.openclaw/skills"
OPENCLAW_FULLSTACK="$OPENCLAW_SKILLS/fullstack"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── 解析 --host 参数 ─────────────────────────────────────────
HOST="openclaw"
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "缺少 --host 的值（期望 openclaw, codex, kiro 或 auto）" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  openclaw|claude|codex|kiro|auto) ;;
  *) echo "未知的 --host 值: $HOST（期望 openclaw, claude, codex, kiro 或 auto）" >&2; exit 1 ;;
esac

# 对于 auto: 检测已安装的代理
INSTALL_OPENCLAW=0
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_KIRO=0
if [ "$HOST" = "auto" ]; then
  command -v openclaw >/dev/null 2>&1 && INSTALL_OPENCLAW=1
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v kiro-cli >/dev/null 2>&1 && INSTALL_KIRO=1
  # 如果都没找到，默认为 openclaw
  if [ "$INSTALL_OPENCLAW" -eq 0 ] && [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_KIRO" -eq 0 ]; then
    INSTALL_OPENCLAW=1
  fi
elif [ "$HOST" = "openclaw" ]; then
  INSTALL_OPENCLAW=1
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "kiro" ]; then
  INSTALL_KIRO=1
fi

migrate_direct_codex_install() {
  local fullstack_dir="$1"
  local codex_fullstack="$2"
  local migrated_dir="$HOME/.fullstack/repos/fullstack"

  [ "$fullstack_dir" = "$codex_fullstack" ] || return 0
  [ -L "$fullstack_dir" ] && return 0

  mkdir -p "$(dirname "$migrated_dir")"
  if [ -e "$migrated_dir" ] && [ "$migrated_dir" != "$fullstack_dir" ]; then
    echo "fullstack 安装失败: 检测到直接 Codex 安装于 $fullstack_dir" >&2
    echo "已存在迁移仓库于 $migrated_dir；请移走其中一个后重新运行 setup。" >&2
    exit 1
  fi

  echo "正在迁移直接 Codex 安装到 $migrated_dir 以避免重复技能发现..."
  mv "$fullstack_dir" "$migrated_dir"
  SOURCE_FULLSTACK_DIR="$migrated_dir"
  INSTALL_FULLSTACK_DIR="$migrated_dir"
  INSTALL_SKILLS_DIR="$(dirname "$INSTALL_FULLSTACK_DIR")"
  BROWSE_BIN="$SOURCE_FULLSTACK_DIR/browse/dist/browse"
}

if [ "$INSTALL_CODEX" -eq 1 ]; then
  migrate_direct_codex_install "$SOURCE_FULLSTACK_DIR" "$OPENCLAW_FULLSTACK"
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    # Windows 上，Bun 无法启动 Chromium（管道处理问题）
    # (oven-sh/bun#4253)。使用 Node.js 来验证 Chromium 是否工作。
    (
      cd "$SOURCE_FULLSTACK_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$SOURCE_FULLSTACK_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

# 1. 按需构建 browse 二进制文件（智能重建：源码过期、package.json、lock 文件）
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_FULLSTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SOURCE_FULLSTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SOURCE_FULLSTACK_DIR/bun.lock" ] && [ "$SOURCE_FULLSTACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "正在构建 browse 二进制文件..."
  (
    cd "$SOURCE_FULLSTACK_DIR"
    bun install
    bun run build
  )
  # 安全网：如果构建脚本没有写入 .version（例如构建期间 git 不可用）
  if [ ! -f "$SOURCE_FULLSTACK_DIR/browse/dist/.version" ]; then
    git -C "$SOURCE_FULLSTACK_DIR" rev-parse HEAD > "$SOURCE_FULLSTACK_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "fullstack 安装失败: browse 二进制文件缺失于 $BROWSE_BIN" >&2
  exit 1
fi

# 1b. 如果缺失或过期则生成 .agents/ Codex 技能文档
# .agents/ 不再提交 — 在 setup 时从 .tmpl 模板生成。
# bun run build 已经做了这个，但我们需要在 NEEDS_BUILD=0 时也做
# （二进制文件是新的但 .agents/ 还没生成，例如新克隆的仓库）。
AGENTS_DIR="$SOURCE_FULLSTACK_DIR/.agents/skills"
NEEDS_AGENTS_GEN=0
if [ ! -d "$AGENTS_DIR" ]; then
  NEEDS_AGENTS_GEN=1
elif [ -n "$(find "$SOURCE_FULLSTACK_DIR" -maxdepth 2 -name 'SKILL.md.tmpl' -newer "$AGENTS_DIR" -print -quit 2>/dev/null)" ]; then
  NEEDS_AGENTS_GEN=1
fi

if [ "$NEEDS_AGENTS_GEN" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  echo "正在生成 .agents/ 技能文档..."
  (
    cd "$SOURCE_FULLSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host codex
  )
fi

# 2. 确保 Playwright 的 Chromium 可用
if ! ensure_playwright_browser; then
  echo "正在安装 Playwright Chromium..."
  (
    cd "$SOURCE_FULLSTACK_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    # Windows 上，Node.js 启动 Chromium（不是 Bun — 见 oven-sh/bun#4253）。
    # 确保 playwright 可以被 Node 从 fullstack 目录导入。
    if ! command -v node >/dev/null 2>&1; then
      echo "fullstack 安装失败: Windows 上需要 Node.js（Bun 由于管道 bug 无法启动 Chromium）" >&2
      echo "  安装 Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "检测到 Windows — 正在验证 Node.js 可以加载 Playwright..."
    (
      cd "$SOURCE_FULLSTACK_DIR"
      # Bun 的 node_modules 已经有 playwright；验证 Node 可以 require 它
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "fullstack 安装失败: 无法通过 Node.js 启动 Playwright Chromium" >&2
    echo "  这是 Bun 在 Windows 上的已知问题 (oven-sh/bun#4253)。" >&2
    echo "  请确保已安装 Node.js 且 'node -e \"require('playwright')\"' 可以工作。" >&2
  else
    echo "fullstack 安装失败: 无法启动 Playwright Chromium" >&2
  fi
  exit 1
fi

# 3. 确保 ~/.fullstack 全局状态目录存在
mkdir -p "$HOME/.fullstack/projects"

# ─── 辅助函数: 将 Claude 技能子目录链接到技能父目录 ──
link_claude_skill_dirs() {
  local fullstack_dir="$1"
  local skills_dir="$2"
  local linked=()
  for skill_dir in "$fullstack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # 跳过 node_modules
      [ "$skill_name" = "node_modules" ] && continue
      target="$skills_dir/$skill_name"
      # 创建或更新符号链接；如果存在真实文件/目录则跳过
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "fullstack/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  已链接技能: ${linked[*]}"
  fi
}

# ─── 辅助函数: 将生成的 Codex 技能链接到技能父目录 ──
# 从 .agents/skills/fullstack-* 安装（生成的 Codex 格式技能）
# 而不是源目录（它们有 Claude 路径）。
link_codex_skill_dirs() {
  local fullstack_dir="$1"
  local skills_dir="$2"
  local agents_dir="$fullstack_dir/.agents/skills"
  local linked=()

  if [ ! -d "$agents_dir" ]; then
    echo "  正在生成 .agents/ 技能文档..."
    ( cd "$fullstack_dir" && bun run gen:skill-docs --host codex )
  fi

  if [ ! -d "$agents_dir" ]; then
    echo "  警告: .agents/skills/ 生成失败 — 请手动运行 'bun run gen:skill-docs --host codex'" >&2
    return 1
  fi

  for skill_dir in "$agents_dir"/fullstack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # 跳过 sidecar 目录 — 它包含运行时资产符号链接（bin/、browse/），
      # 不是技能。链接它会覆盖步骤 5 已指向仓库根目录的 fullstack 符号链接。
      [ "$skill_name" = "fullstack" ] && continue
      target="$skills_dir/$skill_name"
      # 创建或更新符号链接
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  已链接技能: ${linked[*]}"
  fi
}

# ─── 辅助函数: 创建 .agents/skills/fullstack/ sidecar 符号链接 ──────────
# Codex/Gemini/Cursor 从 .agents/skills/ 读取技能。我们链接运行时
# 资产（bin/、browse/dist/、review/、qa/ 等）以便技能模板可以
# 解析像 $SKILL_ROOT/review/design-checklist.md 这样的路径。
create_agents_sidecar() {
  local repo_root="$1"
  local agents_fullstack="$repo_root/.agents/skills/fullstack"
  mkdir -p "$agents_fullstack"

  # 技能在运行时引用的 sidecar 目录
  for asset in bin browse review qa; do
    local src="$SOURCE_FULLSTACK_DIR/$asset"
    local dst="$agents_fullstack/$asset"
    if [ -d "$src" ] || [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done

  # 技能在运行时引用的 sidecar 文件
  for file in ETHOS.md; do
    local src="$SOURCE_FULLSTACK_DIR/$file"
    local dst="$agents_fullstack/$file"
    if [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done
}

# ─── 辅助函数: 创建最小化的 ~/.codex/skills/fullstack 运行时根目录 ───────────
# Codex 递归扫描 ~/.codex/skills。在这里暴露整个仓库会导致
# 重复技能，因为源 SKILL.md 文件和生成的 Codex 技能都会被发现。
# 保持此目录仅包含运行时资产 + 根技能。
create_codex_runtime_root() {
  local fullstack_dir="$1"
  local codex_fullstack="$2"
  local agents_dir="$fullstack_dir/.agents/skills"

  if [ -L "$codex_fullstack" ]; then
    rm -f "$codex_fullstack"
  elif [ -d "$codex_fullstack" ] && [ "$codex_fullstack" != "$fullstack_dir" ]; then
    # 旧的直接安装在这里留下了真实目录和过时的源技能。
    # 删除它以便我们只从最小化的运行时资产开始。
    rm -rf "$codex_fullstack"
  fi

  mkdir -p "$codex_fullstack" "$codex_fullstack/browse" "$codex_fullstack/review"

  if [ -f "$agents_dir/fullstack/SKILL.md" ]; then
    ln -snf "$agents_dir/fullstack/SKILL.md" "$codex_fullstack/SKILL.md"
  fi
  if [ -d "$fullstack_dir/bin" ]; then
    ln -snf "$fullstack_dir/bin" "$codex_fullstack/bin"
  fi
  if [ -d "$fullstack_dir/browse/dist" ]; then
    ln -snf "$fullstack_dir/browse/dist" "$codex_fullstack/browse/dist"
  fi
  if [ -d "$fullstack_dir/browse/bin" ]; then
    ln -snf "$fullstack_dir/browse/bin" "$codex_fullstack/browse/bin"
  fi
  # Review 运行时资产（单个文件，不是整个 review/ 目录，因为它有 SKILL.md）
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$fullstack_dir/review/$f" ]; then
      ln -snf "$fullstack_dir/review/$f" "$codex_fullstack/review/$f"
    fi
  done
  # ETHOS.md — 所有技能 preamble 中的 "Search Before Building" 引用它
  if [ -f "$fullstack_dir/ETHOS.md" ]; then
    ln -snf "$fullstack_dir/ETHOS.md" "$codex_fullstack/ETHOS.md"
  fi
}

# 4. 为 OpenClaw 安装（默认）
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"
SKILLS_PARENT_BASENAME="$(basename "$(dirname "$INSTALL_SKILLS_DIR")")"
CODEX_REPO_LOCAL=0
if [ "$SKILLS_BASENAME" = "skills" ] && [ "$SKILLS_PARENT_BASENAME" = ".agents" ]; then
  CODEX_REPO_LOCAL=1
fi

if [ "$INSTALL_OPENCLAW" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    link_claude_skill_dirs "$SOURCE_FULLSTACK_DIR" "$INSTALL_SKILLS_DIR"
    echo "fullstack 已就绪 (openclaw)。"
    echo "  browse: $BROWSE_BIN"
  else
    echo "fullstack 已就绪 (openclaw)。"
    echo "  browse: $BROWSE_BIN"
    echo "  （跳过技能符号链接 — 不在 .openclaw/skills/ 内）"
  fi
fi

if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  CLAUDE_SKILLS="$HOME/.claude/skills"
  CLAUDE_FULLSTACK="$CLAUDE_SKILLS/fullstack"
  mkdir -p "$CLAUDE_SKILLS"
  create_codex_runtime_root "$SOURCE_FULLSTACK_DIR" "$CLAUDE_FULLSTACK"
  link_codex_skill_dirs "$SOURCE_FULLSTACK_DIR" "$CLAUDE_SKILLS"
  echo "fullstack 已就绪 (claude)。"
  echo "  browse: $BROWSE_BIN"
  echo "  claude skills: $CLAUDE_SKILLS"
fi

# 5. 为 Codex 安装
if [ "$INSTALL_CODEX" -eq 1 ]; then
  if [ "$CODEX_REPO_LOCAL" -eq 1 ]; then
    OPENCLAW_SKILLS="$INSTALL_SKILLS_DIR"
    OPENCLAW_FULLSTACK="$INSTALL_FULLSTACK_DIR"
  fi
  mkdir -p "$OPENCLAW_SKILLS"

  # 对于仓库本地安装跳过运行时根目录创建 — 检出就是运行时根目录。
  # create_codex_runtime_root 会创建自引用符号链接（bin → bin 等）。
  if [ "$CODEX_REPO_LOCAL" -eq 0 ]; then
    create_codex_runtime_root "$SOURCE_FULLSTACK_DIR" "$OPENCLAW_FULLSTACK"
  fi
  # 安装生成的 Codex 格式技能（不是 Claude 源目录）
  link_codex_skill_dirs "$SOURCE_FULLSTACK_DIR" "$OPENCLAW_SKILLS"

  echo "fullstack 已就绪 (codex)。"
  echo "  browse: $BROWSE_BIN"
  echo "  codex skills: $OPENCLAW_SKILLS"
fi

# 6. 为 Kiro CLI 安装（从 .agents/skills 复制，重写路径）
if [ "$INSTALL_KIRO" -eq 1 ]; then
  KIRO_SKILLS="$HOME/.kiro/skills"
  AGENTS_DIR="$SOURCE_FULLSTACK_DIR/.agents/skills"
  mkdir -p "$KIRO_SKILLS"

  # 创建 fullstack 目录，包含运行时资产的符号链接，复制+sed 处理 SKILL.md
  KIRO_FULLSTACK="$KIRO_SKILLS/fullstack"
  # 移除旧安装的整个目录符号链接
  [ -L "$KIRO_FULLSTACK" ] && rm -f "$KIRO_FULLSTACK"
  mkdir -p "$KIRO_FULLSTACK" "$KIRO_FULLSTACK/browse" "$KIRO_FULLSTACK/review"
  ln -snf "$SOURCE_FULLSTACK_DIR/bin" "$KIRO_FULLSTACK/bin"
  ln -snf "$SOURCE_FULLSTACK_DIR/browse/dist" "$KIRO_FULLSTACK/browse/dist"
  ln -snf "$SOURCE_FULLSTACK_DIR/browse/bin" "$KIRO_FULLSTACK/browse/bin"
  # ETHOS.md — 所有技能 preamble 中的 "Search Before Building" 引用它
  if [ -f "$SOURCE_FULLSTACK_DIR/ETHOS.md" ]; then
    ln -snf "$SOURCE_FULLSTACK_DIR/ETHOS.md" "$KIRO_FULLSTACK/ETHOS.md"
  fi
  # Review 运行时资产（单个文件，不是整个目录）
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$SOURCE_FULLSTACK_DIR/review/$f" ]; then
      ln -snf "$SOURCE_FULLSTACK_DIR/review/$f" "$KIRO_FULLSTACK/review/$f"
    fi
  done

  # 为 Kiro 重写根 SKILL.md 路径
  sed -e "s|~/.openclaw/skills/fullstack|~/.kiro/skills/fullstack|g" \
      -e "s|.openclaw/skills/fullstack|.kiro/skills/fullstack|g" \
      -e "s|.openclaw/skills|.kiro/skills|g" \
      "$SOURCE_FULLSTACK_DIR/SKILL.md" > "$KIRO_FULLSTACK/SKILL.md"

  if [ ! -d "$AGENTS_DIR" ]; then
    echo "  警告: 未找到 .agents/skills/ 目录 — 请先运行 'bun run build'" >&2
  else
    for skill_dir in "$AGENTS_DIR"/fullstack*/; do
      [ -f "$skill_dir/SKILL.md" ] || continue
      skill_name="$(basename "$skill_dir")"
      target_dir="$KIRO_SKILLS/$skill_name"
      mkdir -p "$target_dir"
      # 生成的 Codex 技能使用 $HOME/.codex（不是 ~/），加上 $FULLSTACK_ROOT 变量。
      # 重写默认 FULLSTACK_ROOT 值和任何剩余的字面路径。
      sed -e 's|\$HOME/.codex/skills/fullstack|\$HOME/.kiro/skills/fullstack|g' \
          -e "s|~/.codex/skills/fullstack|~/.kiro/skills/fullstack|g" \
          -e "s|~/.openclaw/skills/fullstack|~/.kiro/skills/fullstack|g" \
          "$skill_dir/SKILL.md" > "$target_dir/SKILL.md"
    done
    echo "fullstack 已就绪 (kiro)。"
    echo "  browse: $BROWSE_BIN"
    echo "  kiro skills: $KIRO_SKILLS"
  fi
fi

# 7. 创建 .agents/ sidecar 符号链接用于真实的 Codex 技能目标。
# 根 Codex 技能最终指向 $SOURCE_FULLSTACK_DIR/.agents/skills/fullstack，
# 所以运行时资产必须在那里，无论是全局安装还是仓库本地安装。
if [ "$INSTALL_CODEX" -eq 1 ]; then
  create_agents_sidecar "$SOURCE_FULLSTACK_DIR"
fi

# 8. 首次欢迎
if [ ! -d "$HOME/.fullstack" ]; then
  mkdir -p "$HOME/.fullstack"
  echo "  欢迎使用 FullStack Skills！"
fi
